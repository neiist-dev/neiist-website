                "description": "Do you like videogames? Then this event was made with you in mind! Gather a team and come spend the day with us playing, eating and drinking... and maybe win a prize!"
            },
            "sweats": {
                "title": "Sweats EIC",
                "description": "Want a course hoodie? NEIIST have the best hoodies for the best course!"
            },
            "layout": {
                "title": "Layout Sweats Contest",
                "description": "The Layout Sweats Contest is your opportunity to create the official layout for the special edition each year. If you are a student of EIC at IST, you can submit up to 3 original designs. If you win the online voting, you win the sweat!"
            },
            "churras": {
                "title": "EIC's BBQ",
                "description": "Even if it was a week of projects or exams, there would always be time for a get-together with friends!"
            },
            "jantar_curso": {
                "title": "Course Dinner",
                "description": "Feeling stressed with Técnico? So are we, join your classmates for the best course dinner! The beer is already waiting for you…"
            },
            "ltal": {
                "title": "Let's Talk about LEIC",
                "description": "Starting the course and feeling lost? Come learn all the tricks to survive with us! With this event, alongside older students, you will understand how LEIC and its subjects work."
            },
            "qtsm": {
                "title": "(Almost) Everything about MEIC",
                "description": "Starting MEIC? If you are unsure about which areas or courses to choose, come attend these sessions! They will explain everything you need to know about the master's structure, curriculum, different specialization areas, thesis and much more."
            },
            "python": {
                "title": "Python Workshop",
                "description": "Feeling worried about the FP project or want to learn more about Python? Come to this workshop where we will talk about the main foundations of programming and teach you the essential steps for the computer world!"
            },
            "assembly": {
                "title": "Assembly Workshop",
                "description": "Don't know what MOV, ADD, CMP means? Don't know what registers and flags are? Then join us in this workshop where we will teach you the basics of Assembly that will be fundamental in IAC!"
            },
            "c": {
                "title": "C Workshop",
                "description": "Want to finally understand what memory allocation is, what pointers are, how the stack works and much more? Join us in this workshop and clear all your doubts!"
            },
            "hashcode": {
                "title": "Hash Code",
                "description": "Join us in the coding competition developed by Google in which NEIIST organizes a Hub where all Técnico students are welcome to integrate and participate."
            },
            "lip": {
                "title": "Linux Install Party",
                "description": "Come install Linux on your PC, alongside students with experience in the area and in installing the various flavors that Linux has to offer!"
            }
    
        }
